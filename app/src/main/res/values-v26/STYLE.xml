<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Schermata">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/SfondoApp</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="Intestazione">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="TitoloSchermata">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/TestoPrincipale</item>
    </style>

    <style name="BotoneChiudi">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/TestoBotoneChiudi</item>
        <item name="android:backgroundTint">@color/SfondoApp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="Sezione">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:background">@color/SfondoSezione</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>

    <style name="Etichetta">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/TestoSecondario</item>
    </style>

    <style name="Selettore">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">65dp</item>
    </style>

    <style name="CampoTesto">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="BotoneCalcola">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/SfondoSezione</item>
        <item name="android:backgroundTint">@color/Primario</item>
    </style>

    <style name="Risultato">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">20dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/Primario</item>
        <item name="android:background">@color/SfondoSezione</item>
    </style>
</resources>