<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <LinearLayout
        style="@style/Schermata">
        <LinearLayout style="@style/Intestazione">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <TextView
                style="@style/TitoloSchermata"
                android:text="Dermatologia" />

        </LinearLayout>
        <Button
            android:id="@+id/BSA"
            android:text="BSA"
            style="@style/BotoneCalcola"
            />
        <Button
            android:id="@+id/EASI"
            style="@style/BotoneCalcola"
            android:text="EASI"
            />

        <Button
            android:id="@+id/PASI"
            style="@style/BotoneCalcola"
            android:text="PASI "
            />

        <Button
            android:id="@+id/BMI"
            style="@style/BotoneCalcola"
            android:text="BMI"
            />

    </LinearLayout>

</ScrollView>