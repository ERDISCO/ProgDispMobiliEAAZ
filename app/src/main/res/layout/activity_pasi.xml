<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PASI">

    <LinearLayout
        style="@style/Schermata">

        <LinearLayout style="@style/Intestazione">
            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
            <TextView
                style="@style/TitoloSchermata"
                android:text="PASI" />
            <Button
                android:id="@+id/btnIndietroPASI"
                style="@style/BotoneChiudi"
                android:text="✕" />
        </LinearLayout>

        <LinearLayout style="@style/Sezione">
            <TextView
                style="@style/Etichetta"
                android:text="Distretto" />
            <EditText
                android:id="@+id/DistrettoPASI"
                style="@style/CampoTesto"
                android:hint="H, U, T, L"
                android:inputType="text"
                android:maxLength="1" />
        </LinearLayout>

        <LinearLayout style="@style/Sezione">
            <TextView
                style="@style/Etichetta"
                android:text="Eritema (0–4)" />
            <EditText
                android:id="@+id/EritemaPASI"
                style="@style/CampoTesto"
                android:hint="0-4"
                android:inputType="number"
                android:maxLength="1" />
        </LinearLayout>

        <LinearLayout style="@style/Sezione">
            <TextView
                style="@style/Etichetta"
                android:text="Indurimento (0–4)" />
            <EditText
                android:id="@+id/IndurimentoPASI"
                style="@style/CampoTesto"
                android:hint="0-4"
                android:inputType="number"
                android:maxLength="1" />
        </LinearLayout>

        <LinearLayout style="@style/Sezione">
            <TextView
                style="@style/Etichetta"
                android:text="Desquamazione (0–4)" />
            <EditText
                android:id="@+id/DesquamazionePASI"
                style="@style/CampoTesto"
                android:hint="0-4"
                android:inputType="number"
                android:maxLength="1" />
        </LinearLayout>

        <LinearLayout style="@style/Sezione">
            <TextView
                style="@style/Etichetta"
                android:text="Area Coinvolta (0–6)" />
            <EditText
                android:id="@+id/AreaCoinPASI"
                style="@style/CampoTesto"
                android:hint="0-6"
                android:inputType="number"
                android:maxLength="1" />
        </LinearLayout>

        <Button
            android:id="@+id/PASICalculator"
            style="@style/BotoneCalcola"
            android:text="CALCOLA" />

        <TextView
            android:id="@+id/tvRisultatiPASI"
            style="@style/Risultato"
            android:hint="Risultato" />
        <TextView
            android:id="@+id/tvLivelloPASI"
            style="@style/Risultato"
            android:hint="Livello" />

    </LinearLayout>
</ScrollView>
